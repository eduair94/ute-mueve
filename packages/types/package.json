{
  "name": "@ute-mueve/types",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Zod schemas + quicktype-generated interfaces for the UTE Mueve API (unofficial).",
  "license": "MIT",
  "author": " <admin@checkleaked.cc>",
  "homepage": "https://ute-mueve.vercel.app",
  "repository": { "type": "git", "url": "https://github.com/eduair94/ute-mueve.git", "directory": "packages/types" },
  "bugs": { "url": "https://github.com/eduair94/ute-mueve/issues" },
  "keywords": ["ute", "ute-mueve", "ev", "charging", "uruguay", "zod", "types"],
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./generated": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "5.6.3",
    "vitest": "^2.1.4"
  }
}
