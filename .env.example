# Required: 12-13 hex char device key sent on every UTE upstream call.
# Generate one with:
#   node -e "console.log([...crypto.getRandomValues(new Uint8Array(7))].map(b=>b.toString(16).padStart(2,'0')).join('').slice(0,13))"
UTE_UNIQUE_KEY=

# Required for `pnpm capture`: a Uruguayan CI (valid check digit) you control.
UTE_USER_ID=

# Optional shared token cache (Upstash Redis). Without it, the bridge falls back
# to per-instance in-memory caching (fine for dev / low traffic).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Toggle write-side endpoints (register card, start/stop charge, register FCM).
# Default false. Setting true exposes real account-modifying operations.
ENABLE_WRITE_ENDPOINTS=false

# Comma-separated allowlist for CORS. Default "*" (open).
# CORS_ORIGINS=https://my-frontend.com,https://staging.my-frontend.com

# pino log level. Default info.
# LOG_LEVEL=debug
